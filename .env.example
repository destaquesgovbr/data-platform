# ==========================================================================
# PostgreSQL (docker-compose local dev)
# ==========================================================================
POSTGRES_USER=destaquesgovbr_dev
POSTGRES_PASSWORD=dev_password
POSTGRES_DB=destaquesgovbr_dev
POSTGRES_PORT=5433

# Database URL (used by application, scripts, and tests)
DATABASE_URL=postgresql://destaquesgovbr_dev:dev_password@localhost:5433/destaquesgovbr_dev

# ==========================================================================
# Typesense
# ==========================================================================
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=
TYPESENSE_CONNECTION_TIMEOUT_SECONDS=10

# ==========================================================================
# HuggingFace
# ==========================================================================
HF_TOKEN=
HF_REPO_ID=destaquesgovbr/govbrnews

# ==========================================================================
# Storage
# ==========================================================================
STORAGE_BACKEND=postgres
STORAGE_READ_FROM=postgres

# ==========================================================================
# Embeddings
# ==========================================================================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
EMBEDDING_BATCH_SIZE=32

# ==========================================================================
# GCP
# ==========================================================================
GCP_PROJECT_ID=
GCS_BUCKET=

# ==========================================================================
# Application
# ==========================================================================
LOG_LEVEL=INFO
DEBUG=false
TESTING=1
